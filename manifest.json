{
  "manifest_version": 3,
  "name": "AutoMFA - Secure 2FA Auto-filler",
  "version": "1.4",
  "description": "Securely generates and auto-fills 2FA TOTP codes for seamless Microsoft logins.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["storage", "contextMenus", "notifications"],
  "host_permissions": ["<all_urls>"]
}